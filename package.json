{
    "name": "effeen",
    "description": "基于effect-ts的缓动动画库",
    "version": "0.0.1-alpha",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist"],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "playground": "npx tsx tests/playground.ts"
    },
    "dependencies": {
        "effect": "^3.21.4"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.4",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "jiti": "^2.7.0",
        "prettier": "^3.9.4",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.1.3",
        "vite-plugin-dts": "^5.0.3",
        "vitest": "^4.1.9"
    }
}
